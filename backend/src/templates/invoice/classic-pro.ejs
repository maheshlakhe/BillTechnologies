<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Classic Professional Invoice</title>
    <style>
        body {
            font-family: 'Times New Roman', Times, serif;
            margin: 0;
            padding: 50px;
            color: #000;
        }
        .header {
            text-align: center;
            border-bottom: 3px double #000;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .header h1 {
            margin: 0;
            font-size: 32px;
            text-transform: uppercase;
        }
        .invoice-title {
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            margin: 20px 0;
            text-decoration: underline;
        }
        .info-grid {
            display: table;
            width: 100%;
            margin-bottom: 30px;
        }
        .info-col {
            display: table-cell;
            width: 50%;
            vertical-align: top;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            border: 1px solid #000;
            padding: 10px;
            background: #eee;
        }
        td {
            border: 1px solid #000;
            padding: 10px;
        }
        .totals {
            margin-top: 20px;
            float: right;
            width: 40%;
        }
        .totals table td {
            border: none;
            padding: 5px;
        }
        .grand-total {
            border-top: 1.5px solid #000 !important;
            border-bottom: 1.5px solid #000 !important;
            font-weight: bold;
        }
        .footer {
            clear: both;
            margin-top: 100px;
            display: flex;
            justify-content: space-between;
        }
        .signature {
            border-top: 1px solid #000;
            width: 200px;
            text-align: center;
            padding-top: 5px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1><%= business.name %></h1>
        <p><%= business.address %></p>
        <p>GSTIN: <%= business.gst %> | Phone: <%= business.phone %></p>
    </div>

    <div class="invoice-title">TAX INVOICE</div>

    <div class="info-grid">
        <div class="info-col">
            <p><strong>BILLED TO:</strong></p>
            <p><%= bill.customerName %></p>
            <p><%= bill.customerAddress %></p>
            <p>GSTIN: <%= bill.customerGst || 'N/A' %></p>
        </div>
        <div class="info-col" style="text-align: right;">
            <p><strong>Invoice No:</strong> <%= bill.number %></p>
            <p><strong>Date:</strong> <%= bill.date %></p>
            <p><strong>Payment Mode:</strong> <%= bill.paymentMode %></p>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th style="width: 50px;">Sr.</th>
                <th>Particulars</th>
                <th style="width: 80px;">Qty</th>
                <th style="width: 120px;">Rate</th>
                <th style="width: 120px;">Amount</th>
            </tr>
        </thead>
        <tbody>
            <% bill.items.forEach((item, index) => { %>
                <tr>
                    <td style="text-align: center;"><%= index + 1 %></td>
                    <td><%= item.name %></td>
                    <td style="text-align: center;"><%= item.qty %></td>
                    <td style="text-align: right;"><%= item.rate.toFixed(2) %></td>
                    <td style="text-align: right;"><%= item.total.toFixed(2) %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="totals">
        <table>
            <tr>
                <td>Subtotal:</td>
                <td style="text-align: right;"><%= bill.subtotal.toFixed(2) %></td>
            </tr>
            <tr>
                <td>GST (<%= bill.taxRate %>%):</td>
                <td style="text-align: right;"><%= bill.taxAmount.toFixed(2) %></td>
            </tr>
            <tr class="grand-total">
                <td><strong>GRAND TOTAL:</strong></td>
                <td style="text-align: right;"><strong><%= bill.totalAmount.toFixed(2) %></strong></td>
            </tr>
        </table>
    </div>

    <div class="footer">
        <div>
            <p>Bank Details:</p>
            <p>Bank: HDFC BANK</p>
            <p>A/C No: 502000123456</p>
            <p>IFSC: HDFC0001234</p>
        </div>
        <div>
            <div style="height: 60px;"></div>
            <div class="signature">Authorized Signatory</div>
        </div>
    </div>
</body>
</html>
