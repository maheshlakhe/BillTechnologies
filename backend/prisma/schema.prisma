model IndustryMaster {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  isActive    Boolean  @default(true) @map("is_active")
  
  users       User[]
  formFields  IndustryFormField[]
  dropdownGroups IndustryDropdownGroup[]
  views       IndustryView[]
  permissions IndustryPermission[]
  workflows   IndustryWorkflow[]
  taxRules    IndustryTaxRule[]
  productViewForm IndustryWiseProductViewForm?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industry_master")
}

model IndustryFormField {
  id              String   @id @default(cuid())
  industryId      String   @map("industry_id")
  industry        IndustryMaster @relation(fields: [industryId], references: [id], onDelete: Cascade)
  entity          String   // product, customer, bill, etc.
  name            String   // field name (slug)
  label           String   // display label
  dataType        String   @default("text") // text, number, date, select, dropdown
  required        Boolean  @default(false)
  placeholder     String?
  defaultValue    String?  @map("default_value")
  groupId         String?  @map("group_id")
  group           IndustryDropdownGroup? @relation(fields: [groupId], references: [id])
  order           Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([industryId, entity, name])
  @@map("industry_form_fields")
}

model IndustryDropdownGroup {
  id          String   @id @default(cuid())
  industryId  String   @map("industry_id")
  industry    IndustryMaster @relation(fields: [industryId], references: [id], onDelete: Cascade)
  name        String   // e.g., "Brand", "Warranty Type"
  slug        String
  options     IndustryDropdownOption[]
  fields      IndustryFormField[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([industryId, slug])
  @@map("industry_dropdown_groups")
}

model IndustryDropdownOption {
  id          String   @id @default(cuid())
  groupId     String   @map("group_id")
  group       IndustryDropdownGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  label       String   // e.g., "Samsung", "Apple"
  value       String
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industry_dropdown_options")
}

model IndustryView {
  id          String   @id @default(cuid())
  industryId  String   @map("industry_id")
  industry    IndustryMaster @relation(fields: [industryId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  config      String   // JSON configuration for the view
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industry_views")
}

model IndustryPermission {
  id          String   @id @default(cuid())
  industryId  String   @map("industry_id")
  industry    IndustryMaster @relation(fields: [industryId], references: [id], onDelete: Cascade)
  resource    String
  action      String
  config      String?  // JSON configuration
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industry_permissions")
}

model IndustryWorkflow {
  id          String   @id @default(cuid())
  industryId  String   @map("industry_id")
  industry    IndustryMaster @relation(fields: [industryId], references: [id], onDelete: Cascade)
  name        String
  trigger     String
  steps       String   // JSON steps
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industry_workflows")
}

model IndustryTaxRule {
  id          String   @id @default(cuid())
  industryId  String   @map("industry_id")
  industry    IndustryMaster @relation(fields: [industryId], references: [id], onDelete: Cascade)
  name        String
  rule        String   // JSON rule
  priority    Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industry_tax_rules")
}

model Warehouse {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  address   String?
  city      String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]

  @@map("warehouses")
}

model IndustryWiseProductViewForm {
  id            String         @id @default(cuid())
  industryId    String         @unique @map("industry_id")
  industry      IndustryMaster @relation(fields: [industryId], references: [id], onDelete: Cascade)
  formStructure String         // JSON string defining sections, fields, layout structure
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("industry_wise_product_view_forms")
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String
  key       String    @unique
  scope     String    @default("READ_WRITE") // READ_ONLY, READ_WRITE, ADMIN
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model ThirdPartyOrder {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  orderId         String   @unique @map("order_id")
  platform        String   // ZOMATO or SWIGGY
  customerName    String   @map("customer_name")
  customerPhone   String?  @map("customer_phone")
  deliveryAddress String?  @map("delivery_address")
  items           String   // JSON string of array of order items (name, quantity, price, total)
  subtotal        Float
  taxAmount       Float    @default(0) @map("tax_amount")
  totalAmount     Float    @map("total_amount")
  status          String   @default("PENDING") // PENDING, PREPARING, DISPATCHED, DELIVERED, SETTLED, CANCELLED
  billId          String?  @map("bill_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("third_party_orders")
}

model RestaurantTable {
  id                String             @id @default(cuid())
  userId            String             @map("user_id")
  name              String
  section           String             @default("General") // e.g., "AC", "Non-AC", "Rooftop"
  capacity          Int                @default(4)
  status            String             @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCode            QrCode?
  qrSessions        QrSession[]
  dineInOrders      DineInOrder[]
  waiterActions     WaiterAction[]
  tableActivityLogs TableActivityLog[]

  @@index([userId])
  @@map("restaurant_tables")
}

model QrCode {
  id        String          @id @default(cuid())
  tableId   String          @unique @map("table_id")
  token     String          @unique
  qrCodeUrl String?         @map("qr_code_url")
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  table     RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}

model QrSession {
  id            String          @id @default(cuid())
  userId        String          @map("user_id")
  tableId       String          @map("table_id")
  customerName  String?         @map("customer_name")
  customerPhone String?         @map("customer_phone")
  token         String          @unique
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  endedAt       DateTime?       @map("ended_at")
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  table         RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  orders        DineInOrder[]
  waiterActions WaiterAction[]

  @@index([userId])
  @@index([tableId])
  @@map("qr_sessions")
}

model DineInOrder {
  id          String                   @id @default(cuid())
  userId      String                   @map("user_id")
  tableId     String                   @map("table_id")
  sessionId   String?                  @map("session_id")
  orderNumber String                   @unique @map("order_number")
  status      String                   @default("PENDING") // PENDING, ACCEPTED, PREPARING, READY, SERVED, CANCELLED, SETTLED
  subtotal    Float
  taxAmount   Float                    @default(0) @map("tax_amount")
  totalAmount Float                    @map("total_amount")
  notes       String?
  billId      String?                  @map("bill_id")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  table       RestaurantTable          @relation(fields: [tableId], references: [id], onDelete: Cascade)
  session     QrSession?               @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  items       DineInOrderItem[]
  statusLogs  DineInOrderStatusLog[]
  kitchenQueue KitchenQueue[]

  @@index([userId])
  @@index([tableId])
  @@index([sessionId])
  @@index([status])
  @@map("dine_in_orders")
}

model DineInOrderItem {
  id         String      @id @default(cuid())
  orderId    String      @map("order_id")
  productId  String      @map("product_id")
  name       String
  quantity   Int
  price      Float
  totalPrice Float       @map("total_price")
  notes      String?
  order      DineInOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("dine_in_order_items")
}

model DineInOrderStatusLog {
  id         String      @id @default(cuid())
  orderId    String      @map("order_id")
  fromStatus String      @map("from_status")
  toStatus   String      @map("to_status")
  remarks    String?
  createdAt  DateTime    @default(now()) @map("created_at")
  order      DineInOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("dine_in_order_status_logs")
}

model KitchenQueue {
  id            String      @id @default(cuid())
  orderId       String      @map("order_id")
  status        String      @default("PENDING") // PENDING, PREPARING, READY, SERVED
  estimatedTime Int?        @map("estimated_time")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  order         DineInOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("kitchen_queues")
}

model WaiterAction {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  tableId     String           @map("table_id")
  sessionId   String?          @map("session_id")
  actionType  String           @map("action_type") // CALL_WAITER, REQUEST_BILL, OTHER
  status      String           @default("PENDING") // PENDING, ASSIGNED, COMPLETED
  createdAt   DateTime         @default(now()) @map("created_at")
  completedAt DateTime?        @map("completed_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  table       RestaurantTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  session     QrSession?       @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tableId])
  @@index([sessionId])
  @@map("waiter_actions")
}

model TableActivityLog {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  tableId   String          @map("table_id")
  action    String
  details   String?
  createdAt DateTime        @default(now()) @map("created_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  table     RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tableId])
  @@map("table_activity_logs")
}



