  updatedAt DateTime @updatedAt @map("updated_at")
  users     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Template {
  id           String   @id @default(cuid())
  name         String
  pageSize     String   @map("page_size")
  industry     String?
  billType     String?  @map("bill_type")
  columnConfig String   @default("[]") @map("column_config")
  isSystem     Boolean  @default(false) @map("is_system")
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  bills        Bill[]
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("templates")
}

model ImportJob {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  status            String   @default("PENDING")
  totalProducts     Int      @default(0) @map("total_products")
  processedProducts Int      @default(0) @map("processed_products")
  failedProducts    Int      @default(0) @map("failed_products")
  errorMessage      String?  @map("error_message")
  errorLog          String?  @map("error_log")
  createdAt         DateTime @default(now()) @map("created_at")
