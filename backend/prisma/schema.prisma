model ServiceTicket {
  id                 String              @id @default(cuid())
  userId             String              @map("user_id")
  ticketNumber       String?             @unique @map("ticket_number")
  customerId         String?             @map("customer_id")
  serviceId          String?             @map("service_id")
  deviceInfo         String?             @map("device_info")
  problemDescription String?             @map("problem_description")
  assignedTechnician String?             @map("assigned_technician")
  priority           String              @default("MEDIUM")
  status             ServiceTicketStatus @default(OPEN)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  serviceItems       ServiceItem[]
  service            Service?            @relation(fields: [serviceId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id])
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([customerId])
  @@index([serviceId])
  @@map("service_tickets")
}

model ServiceItem {
  id              String        @id @default(cuid())
  serviceTicketId String        @map("service_ticket_id")
  itemName        String        @map("item_name")
  price           Float
  createdAt       DateTime      @default(now()) @map("created_at")
  serviceTicket   ServiceTicket @relation(fields: [serviceTicketId], references: [id], onDelete: Cascade)

  @@map("service_items")
}

model custom_columns {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  label     String
  dataType  String   @default("text")
  entity    String
  required  Boolean  @default(false)
